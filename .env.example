# ── SOLSCAN ALPHA BOT — Environment Variables ──────────────
# Copy this file to .env and fill in your values
# NEVER commit your .env file to GitHub

# Your Telegram bot token from @BotFather (REQUIRED)
BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port (Render sets this automatically — leave as 3000 locally)
PORT=3000

# Optional: Helius API key for on-chain whale tracking (helius.dev)
HELIUS_API_KEY=

# Optional: BirdEye API key for enriched price data (birdeye.so)
BIRDEYE_API_KEY=
